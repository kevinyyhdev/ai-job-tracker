# Copy this file to .env and fill in your values.
# .env is git-ignored and should never be committed.

# Local database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/job_tracker
SPRING_DATASOURCE_USERNAME=job_tracker_user
SPRING_DATASOURCE_PASSWORD=job_tracker_password

# Active profile (local or test)
SPRING_PROFILES_ACTIVE=local

# JWT (fill in when auth is implemented)
JWT_SECRET=
JWT_EXPIRATION_MS=3600000
